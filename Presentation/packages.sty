\newcommand*{\xgets}[2][]{
  \mathrel{
    \tikz[
      baseline=-0.426ex,
      inner sep=0pt,
      outer sep=0pt,
    ]{
      \ifthenelse{\equal{#2}{}}{}{\node at (0.05, 0.15) {\tiny #2};}
      \node at (0, 0) {$\gets$};
      \ifthenelse{\equal{#1}{}}{}{\node at (0.05, -0.1) {\tiny #1};}
    }
  }
}
\newcommand*{\rgets}{\xgets{R}}
\newcommand*{\sgets}{\xgets{\$}}

